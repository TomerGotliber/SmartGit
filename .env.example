# Fine-grained or classic PAT: repo read + read:org (for team expansion).
# For "Poke reviewer" comments: token must be allowed to post PR/issue comments (e.g. classic repo scope, or fine-grained Pull requests + Issues write).
GITHUB_TOKEN=

# Comma- or space-separated owner/repo, or * / ALL to scan every non-archived repo this token can access
REPOS=*

# Optional (Vite dev proxy uses the same PORT from this file)
PORT=4001
POLL_INTERVAL_MS=60000
LOG_LEVEL=info

# Optional: JSON store for per-PR severity + poke cooldown timestamps (default server/data/pr-meta.json)
# PR_META_PATH=

# Hours between pokes to the same reviewer on the same PR (default 24)
# POKE_COOLDOWN_HOURS=24

# If true, PATCH severity requires body.actorLogin to match the PR author (see UI field)
# REQUIRE_PR_AUTHOR_FOR_SEVERITY=false
