# Fine-grained or classic PAT: repo read + read:org (for team expansion).
# For "Poke reviewer" comments: token must be allowed to post PR/issue comments (e.g. classic repo scope, or fine-grained Pull requests + Issues write).
GITHUB_TOKEN=

# Comma- or space-separated owner/repo, or * / ALL to scan every non-archived repo this token can access
REPOS=*

# Optional: skip repos from REPOS / discovery. Space-, comma-, or semicolon-separated owner/repo entries (no quotes needed).
# The repo slug SmartGit is always excluded (this app). Restart the server after changing this line.
# REPOS_EXCLUDE=corsight-ai/CorsightForensicRunner corsight-ai/CorsightHomeAssignments

# Optional (Vite dev proxy uses the same PORT from this file)
PORT=4001
# Many repos × open PRs = many GitHub REST calls. Increase this to poll less often; the server waits and retries on rate limits.
POLL_INTERVAL_MS=60000
LOG_LEVEL=info

# Optional: JSON store for per-PR metadata (default server/data/pr-meta.json)
# PR_META_PATH=
