# Fine-grained or classic PAT: repo read + read:org (for team member expansion)
GITHUB_TOKEN=

# Comma- or space-separated owner/repo, or * / ALL to scan every non-archived repo this token can access
REPOS=*

# Optional (Vite dev proxy uses the same PORT from this file)
PORT=4001
POLL_INTERVAL_MS=60000
LOG_LEVEL=info
